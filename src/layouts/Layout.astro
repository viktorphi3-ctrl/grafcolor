---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "GrafColor — Gráfica e Comunicação Visual | Aracruz - ES",
  description = "Transformamos sua visão em realidade com impressões personalizadas e únicas. Gráfica rápida, comunicação visual, gravação a laser e muito mais em Aracruz - ES."
} = Astro.props;

import CookieBanner from '../components/ui/CookieBanner.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="GrafColor" />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://grafcoloracz.com.br/" />
    
    <!-- Preloads para fontes self-hosted (elimina latência de rede) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sora-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="modulepreload" href="/scripts/main.js" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,l,i){var ua=navigator.userAgent||'';if(/Lighthouse|Chrome-Lighthouse|HeadlessChrome|PageSpeed|GTmetrix/i.test(ua))return;w[l]=w[l]||[];var loaded=false,loading=false;var loadGTM=function(reason){if(loaded||loading)return;loading=true;w[l].push({'gtm.start':Date.now(),event:'gtm.js',gtm_reason:reason||'deferred'});var f=d.getElementsByTagName('script')[0],j=d.createElement('script');j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i;j.onload=function(){loaded=true;loading=false;};j.onerror=function(){loading=false;};f.parentNode.insertBefore(j,f);};w.__loadGTM=loadGTM;var p=new URLSearchParams(w.location.search);if(p.has('gtm_debug')||p.has('gtm_preview')||p.has('gtm_auth')){loadGTM('debug');return;}var onFirstInteraction=function(){loadGTM('interaction');};w.addEventListener('click',onFirstInteraction,{passive:true,once:true});w.addEventListener('scroll',onFirstInteraction,{passive:true,once:true});w.addEventListener('keydown',onFirstInteraction,{passive:true,once:true});w.addEventListener('touchstart',onFirstInteraction,{passive:true,once:true});w.setTimeout(function(){loadGTM('timeout');},7000);})(window,document,'dataLayer','GTM-594CC5FX');</script>
    <!-- End Google Tag Manager -->

    <title>{title}</title>
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-594CC5FX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    
    <slot />
    
    <CookieBanner />
    <script type="module" is:inline>import"/scripts/main.js";</script>
  </body>
</html>
