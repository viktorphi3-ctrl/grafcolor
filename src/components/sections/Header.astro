---
import { Image } from 'astro:assets';
import logoImage from '../../assets/images/logo.webp';
import logoMobile from '../../assets/images/Logo_360_108.webp';

const navLinks = [
  { label: 'Início', href: '#inicio' },
  { label: 'Serviços', href: '#servicos' },
  { label: 'Portfólio', href: '#portfolio' },
  { label: 'Contato', href: '#contato' },
  { label: 'Sobre', href: '#sobre' },
];
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <!-- Logo -->
      <a href="#inicio" class="flex items-center gap-2 group">
        <picture>
          <source media="(max-width: 767px)" srcset={logoMobile.src} width="180" height="54" />
          <Image src={logoImage} alt="GrafColor" class="h-[72px] w-auto" width={240} height={72} loading="eager" fetchpriority="high" quality={90} />
        </picture>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a 
            href={link.href} 
            class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider hover:text-[var(--color-primary)] focus-visible:text-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-4 focus-visible:ring-offset-black rounded-sm transition-colors duration-300"
          >
            {link.label}
          </a>
        ))}
        <a href="https://drive.google.com/drive/folders/1fJDjEcrzDsQcsiQs5Bo8xrK0tsDbgmwh?usp=sharing" target="_blank" rel="noopener noreferrer" class="hidden lg:flex items-center gap-2 px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-[var(--color-primary)] border border-[var(--color-primary)]/50 rounded-full hover:bg-[var(--color-primary)] hover:text-white transition-all duration-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Portfólio em PDF
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <!-- Aumentado padding de p-2 para p-3 (min 44x44px target) para Fitts's Law -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-3 z-60 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]" aria-label="Menu">
        <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center menu-line-1"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300 menu-line-2"></span>
        <span class="block w-4 h-0.5 bg-white transition-all duration-300 origin-center menu-line-3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden fixed inset-0 bg-[var(--color-bg-primary)]/95 backdrop-blur-xl z-50 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-500">
    {navLinks.map(link => (
      <a 
        href={link.href}
        class="text-2xl font-bold text-white uppercase tracking-wider hover:text-[var(--color-primary)] transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a href="https://drive.google.com/drive/folders/1fJDjEcrzDsQcsiQs5Bo8xrK0tsDbgmwh?usp=sharing" target="_blank" rel="noopener noreferrer" class="mt-4 flex items-center gap-2 px-8 py-3 text-sm font-bold uppercase tracking-wider text-[var(--color-primary)] border-2 border-[var(--color-primary)] rounded-full hover:bg-[var(--color-primary)] hover:text-white transition-all duration-300">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Baixar Portfólio
    </a>
  </div>
</header>

<style>
  #main-header {
    background: transparent;
  }
  #main-header.scrolled {
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-glass-border);
  }
  #menu-toggle.active .menu-line-1 {
    transform: rotate(45deg) translate(3px, 3px);
  }
  #menu-toggle.active .menu-line-2 {
    opacity: 0;
  }
  #menu-toggle.active .menu-line-3 {
    width: 1.5rem;
    transform: rotate(-45deg) translate(3px, -3px);
  }
  #mobile-menu.active {
    opacity: 1;
    pointer-events: auto;
  }
</style>
