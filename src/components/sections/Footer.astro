---
import { Image } from 'astro:assets';
import logoImage from '../../assets/images/logo.webp';
---

<footer class="py-16 bg-[var(--color-bg-surface)] border-t border-[var(--color-glass-border)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="#inicio" class="inline-block mb-4">
          <Image src={logoImage} alt="GrafColor" class="h-16 w-auto" width={200} height={64} loading="lazy" quality={90} />
        </a>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          Transformamos sua visão em realidade com impressões personalizadas e únicas.
        </p>
      </div>

      <!-- Contato -->
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Contato</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-[var(--color-text-secondary)]">
            <svg class="flex-shrink-0 mt-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Av. Florestal, 271A - Centro,<br/>Aracruz - ES</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
            <svg class="flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="22 7 12 13 2 7"/></svg>
            <a href="mailto:contato@grafcoloracz.com.br" class="hover:text-[var(--color-primary)] transition-colors">contato@grafcoloracz.com.br</a>
          </li>
          <li class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
            <svg class="flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+5527997276504" class="hover:text-[var(--color-primary)] transition-colors">(27) 99727-6504</a>
          </li>
        </ul>
      </div>

      <!-- Horário -->
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Horário</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
            <svg class="flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>SEG à SEX, 07 às 17:00</span>
          </li>
        </ul>
        <div class="mt-6">
          <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-3">CNPJ</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">29.494.331/0001-07</p>
        </div>
      </div>

      <!-- Redes Sociais -->
      <div>
        <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Redes Sociais</h3>
        <div class="flex gap-3">
          <!-- Instagram -->
          <a href="https://www.instagram.com/grafcoloracz/" target="_blank" rel="noopener" class="w-11 h-11 rounded-xl bg-[var(--color-glass)] border border-[var(--color-glass-border)] flex items-center justify-center hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-black transition-all duration-300" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <!-- Facebook -->
          <a href="https://www.facebook.com/grafcoloracz/" target="_blank" rel="noopener" class="w-11 h-11 rounded-xl bg-[var(--color-glass)] border border-[var(--color-glass-border)] flex items-center justify-center hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-black transition-all duration-300" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <!-- Google -->
          <a href="https://g.co/kgs/grafcolor" target="_blank" rel="noopener" class="w-11 h-11 rounded-xl bg-[var(--color-glass)] border border-[var(--color-glass-border)] flex items-center justify-center hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-black transition-all duration-300" aria-label="Google">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-[var(--color-glass-border)] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[var(--color-text-muted)] text-center sm:text-left">
        Grafcolor ©{new Date().getFullYear()} — Todos os direitos reservados.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-8">
        <a href="https://moggy.cloud/?utm_source=grafcolor&utm_medium=footer_link&utm_campaign=client_sites" target="_blank" rel="noopener noreferrer" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] rounded-sm">
          Desenvolvido por <strong>Agência Moggy</strong>
        </a>
        <a href="/politica-de-privacidade-e-cookies" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] rounded-sm">
          Política de Privacidade
        </a>
      </div>
    </div>
  </div>
</footer>
