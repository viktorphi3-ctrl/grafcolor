---
---

<section id="contato" class="py-24 relative bg-[var(--color-bg-surface)]/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16 reveal">
      <h2 class="section-title">Solicite um Orçamento</h2>
      <p class="section-subtitle">Preencha os campos abaixo para solicitar sua cotação</p>
    </div>

    <div class="glass-card p-8 sm:p-12 reveal">
      <form id="contact-form" class="space-y-6">
        
        <div class="grid sm:grid-cols-2 gap-6">
          <!-- Nome -->
          <div>
            <label for="nome" class="block text-sm font-semibold text-white mb-2">Nome *</label>
            <input 
              type="text" 
              id="nome" 
              name="nome" 
              required
              class="w-full px-4 py-3 bg-[var(--color-bg-primary)] border border-[var(--color-glass-border)] rounded-xl text-white placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] transition-all duration-300"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-white mb-2">Email *</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              class="w-full px-4 py-3 bg-[var(--color-bg-primary)] border border-[var(--color-glass-border)] rounded-xl text-white placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] transition-all duration-300"
            />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <!-- WhatsApp -->
          <div>
            <label for="whatsapp" class="block text-sm font-semibold text-white mb-2">WhatsApp / Telefone *</label>
            <input 
              type="tel" 
              id="whatsapp" 
              name="whatsapp" 
              required
              class="w-full px-4 py-3 bg-[var(--color-bg-primary)] border border-[var(--color-glass-border)] rounded-xl text-white placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] transition-all duration-300"
            />
          </div>

          <!-- Assunto -->
          <div>
            <label for="assunto" class="block text-sm font-semibold text-white mb-2">Assunto</label>
            <select 
              id="assunto" 
              name="assunto"
              class="w-full px-4 py-3 bg-[var(--color-bg-primary)] border border-[var(--color-glass-border)] rounded-xl text-white focus:outline-none focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] transition-all duration-300"
            >
              <option value="">Selecione um assunto</option>
              <option value="grafica">Gráfica Rápida</option>
              <option value="comunicacao">Comunicação Visual</option>
              <option value="laser">Gravação a Laser</option>
              <option value="criacao">Elaboração e Criação</option>
              <option value="sites">Criação de Sites</option>
              <option value="material">Material de Escritório</option>
              <option value="outro">Outro</option>
            </select>
          </div>
        </div>

        <!-- Mensagem -->
        <div>
          <label for="mensagem" class="block text-sm font-semibold text-white mb-2">Mensagem</label>
          <textarea 
            id="mensagem" 
            name="mensagem" 
            rows="4"
            placeholder="Descreva seu projeto ou solicitação..."
            class="w-full px-4 py-3 bg-[var(--color-bg-primary)] border border-[var(--color-glass-border)] rounded-xl text-white placeholder-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] transition-all duration-300 resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <div class="text-center pt-4">
          <button type="submit" class="btn-primary text-base px-12 py-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Enviar Mensagem
          </button>
        </div>
      </form>

      <!-- Success Message -->
      <div id="form-success" class="hidden text-center py-8">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[var(--color-whatsapp)]/20 flex items-center justify-center">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-whatsapp)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Mensagem Enviada!</h3>
        <p class="text-[var(--color-text-secondary)]">Entraremos em contato em breve. Obrigado!</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const nome = formData.get('nome');
      const whatsapp = formData.get('whatsapp');
      const assunto = formData.get('assunto') || 'Orçamento';
      const mensagem = formData.get('mensagem') || '';
      
      // Build WhatsApp message
      const waMsg = `Olá! Sou ${nome}.\n\nAssunto: ${assunto}\nTelefone: ${whatsapp}\n\n${mensagem}`.trim();
      const waUrl = `https://wa.me/5527997276504?text=${encodeURIComponent(waMsg)}`;
      
      // Show success and redirect
      form.classList.add('hidden');
      success.classList.remove('hidden');
      
      setTimeout(() => {
        window.open(waUrl, '_blank');
      }, 1000);
    });
  }
</script>
