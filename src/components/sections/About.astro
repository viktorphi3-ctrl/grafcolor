---
---

<section id="sobre" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left: Text -->
      <div class="reveal">
        <h2 class="section-title text-left mb-6">Quem Somos?</h2>
        <div class="space-y-4 text-[var(--color-text-secondary)] leading-relaxed">
          <p>
            A <strong class="text-white">Grafcolor</strong> é o seu destino certo para soluções de comunicação visual de alto padrão. Da divulgação à embalagem, nós transformamos suas ideias em peças visualmente incríveis.
          </p>
          <p>
            E não importa se você é um indivíduo ou uma grande empresa, estamos aqui para ajudar a atingir seus objetivos de impressão e comunicação!
          </p>
          <p>
            Localizada em <strong class="text-white">Aracruz - ES</strong>, contamos com uma equipe dedicada e equipamentos de última geração para entregar o melhor resultado em cada projeto.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mt-10">
          <div class="text-center">
            <div class="text-3xl font-extrabold gradient-text">10+</div>
            <div class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest mt-1">Anos de Experiência</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-extrabold gradient-text">500+</div>
            <div class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest mt-1">Clientes Atendidos</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-extrabold gradient-text">100%</div>
            <div class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest mt-1">Satisfação</div>
          </div>
        </div>
      </div>

      <!-- Right: WhatsApp CTA Card -->
      <div class="reveal animate-delay-2">
        <div class="glass-card p-10 text-center relative overflow-hidden">
          <!-- Glow -->
          <div class="absolute top-0 right-0 w-40 h-40 bg-[var(--color-whatsapp)]/10 rounded-full blur-3xl"></div>
          
          <div class="relative">
            <!-- WhatsApp Icon -->
            <div class="w-20 h-20 mx-auto mb-6 bg-[var(--color-whatsapp)] rounded-full flex items-center justify-center shadow-lg shadow-[var(--color-whatsapp)]/30">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>

            <h3 class="text-2xl font-bold text-white mb-3 font-[var(--font-heading)]">Falar no WhatsApp Agora</h3>
            <p class="text-[var(--color-text-secondary)] mb-8">
              Atendimento rápido e personalizado. Clique para iniciar a conversa.
            </p>

            <a 
              href="https://wa.me/5527997276504?text=Olá! Vim pelo site e gostaria de solicitar um orçamento."
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-3 px-10 py-4 bg-[var(--color-whatsapp)] text-white font-bold text-sm uppercase tracking-wider rounded-full hover:bg-[#20bd5a] hover:shadow-lg hover:shadow-[var(--color-whatsapp)]/30 transition-all duration-300 hover:-translate-y-1"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Iniciar Conversa
            </a>

            <p class="text-xs text-[var(--color-text-muted)] mt-4">(27) 99727-6504</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
