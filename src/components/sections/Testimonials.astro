    text: "Preço justo, artes de excelente qualidade e bom atendimento. Variedade em serviços e ótima localização.",
    rating: 5,
    date: "há 5 anos"
  },
  {
    name: "Stéfany Carvalho",
    text: "Excelente atendimento, produtos e serviços de qualidade e preço justo.",
    rating: 5,
    date: "há 4 anos"
  },
  {
    name: "Douglas Tiago Ito",
    text: "Preço justo. Trabalho de qualidade. Pontualidade. Excelente atendimento.",
    rating: 5,
    date: "há 5 anos"
  },
  {
    name: "Letícia Garcia Tirado",
    text: "Excelente atendimento e qualidade nos serviços. Super indico.",
    rating: 5,
    date: "há 4 anos"
  },
  {
    name: "José Nilson Antunes",
    text: "Entrega rápida, bom preço e profissionais competentes.",
    rating: 5,
    date: "há 5 anos"
  },
  {
    name: "Rodrigo Garcia",
    text: "SUPER INDICO! A melhor da cidade!!",
    rating: 5,
    date: "há 4 anos"
  },
  {
    name: "Ioná Caballero",
    text: "Adoreiii o atendimento, preço e qualidade. Super recomendo ;)",
    rating: 5,
    date: "há 5 anos"
  },
  {
    name: "Rafael Fudil",
    text: "Serviço de qualidade e excelência!",
    rating: 5,
    date: "há 1 ano"
  },
  {
    name: "Carla Mascaro",
    text: "Ótimo atendimento, Qualidade top!",
    rating: 5,
    date: "há 5 anos"
  },
  {
    name: "Bruno",
    text: "Qualidade, confiança e preço justo!",
    rating: 5,
    date: "há 1 ano"
  },
