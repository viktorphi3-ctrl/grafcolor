---
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden pt-20">
  <!-- Background Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-bg-primary)] via-[var(--color-bg-primary)] to-purple-950/30"></div>
  
  <!-- Glowing Orbs -->
  <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-[var(--color-primary)]/10 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-1/4 left-1/4 w-80 h-80 bg-[var(--color-secondary)]/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  
  <!-- Grid Pattern -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2240%22%20height%3D%2240%22%20viewBox%3D%220%200%2040%2040%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M0%200h40v40H0z%22%20fill%3D%22none%22%20stroke%3D%22rgba(255%2C255%2C255%2C0.03)%22%20stroke-width%3D%221%22%2F%3E%3C%2Fsvg%3E')] opacity-50"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pb-24 md:pb-0">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left Content -->
      <div class="space-y-8 text-center lg:text-left">
        <div class="animate-fade-in-up">
          <span class="inline-block px-4 py-2 text-xs font-semibold uppercase tracking-widest text-[var(--color-primary)] border border-[var(--color-primary)]/30 rounded-full bg-[var(--color-primary)]/5 mb-6">
            Gráfica e Comunicação Visual
          </span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight animate-fade-in-up animate-delay-1">
          TRANSFORMAMOS
          <span class="block gradient-text">SUA VISÃO EM REALIDADE</span>
          <span class="block text-3xl sm:text-4xl lg:text-5xl mt-2">COM IMPRESSÕES <span class="gradient-text">PERSONALIZADAS E ÚNICAS.</span></span>
        </h1>
        
        <p class="text-lg text-[var(--color-text-secondary)] max-w-xl mx-auto lg:mx-0 animate-fade-in-up animate-delay-2">
          Desde a elaboração até a impressão, recorte e acabamentos. Somos especialistas em <strong class="text-white">Placas de Sinalização Industrial</strong>.
        </p>
        
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start animate-fade-in-up animate-delay-3">
          <a href="https://wa.me/5527997276504?text=Olá! Gostaria de mais informações." class="btn-primary" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Entrar em Contato
          </a>
          <a href="#contato" class="btn-outline">
            Solicitar Orçamento
          </a>
          <a href="https://drive.google.com/drive/folders/1fJDjEcrzDsQcsiQs5Bo8xrK0tsDbgmwh?usp=sharing" target="_blank" rel="noopener noreferrer" class="btn-outline border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white transition-all duration-300">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 inline"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Baixar Portfólio
          </a>
        </div>
      </div>

      <!-- Right - Hero Image -->
      <div class="hidden lg:block relative animate-fade-in-up animate-delay-4">
        <div class="relative">
          <!-- Glow effect behind image -->
          <div class="absolute inset-0 bg-gradient-to-tr from-[var(--color-primary)]/20 to-[var(--color-secondary)]/20 rounded-3xl blur-2xl scale-110"></div>
          <!-- Image container -->
          <div class="relative rounded-3xl overflow-hidden border border-[var(--color-glass-border)] shadow-2xl shadow-[var(--color-primary)]/10">
            <img 
              src="/impressora.webp" 
              alt="Impressora industrial GrafColor - Qualidade de impressão profissional" 
              class="w-full h-auto object-cover"
              width="600"
              height="400"
              loading="eager"
            />
            <!-- Gradient overlay bottom -->
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)]/60 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hidden md:flex absolute bottom-8 left-1/2 -translate-x-1/2 flex-col items-center gap-2 animate-bounce">
    <span class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest">Scroll</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>
  </div>
</section>
