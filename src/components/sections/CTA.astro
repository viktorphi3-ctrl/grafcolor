<section class="py-20 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 gradient-bg opacity-90"></div>
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2240%22%20height%3D%2240%22%20viewBox%3D%220%200%2040%2040%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M0%200h40v40H0z%22%20fill%3D%22none%22%20stroke%3D%22rgba(255%2C255%2C255%2C0.1)%22%20stroke-width%3D%221%22%2F%3E%3C%2Fsvg%3E')]"></div>
  
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-white uppercase mb-4 font-[var(--font-heading)]">
      Precisando de Mais Informações?
    </h2>
    <p class="text-lg text-white/80 mb-8">
      Solicite um orçamento personalizado agora mesmo.
    </p>
    <a 
      href="#contato" 
      class="inline-flex items-center gap-3 px-10 py-4 bg-white text-[var(--color-bg-primary)] font-bold text-sm uppercase tracking-wider rounded-full hover:bg-white/90 hover:shadow-2xl hover:shadow-white/20 transition-all duration-300 hover:-translate-y-1"
    >
      Solicitar Orçamento
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</section>
